# Game data (copied from a Satisfactory install — not redistributable)
game-data/
# The raw docs file is never committed (retired in #162); the extractor reads it
# from the game install and bundles only the derived sf-game-data.json per channel.
packages/sf-game-data/data/*/en-US.json
packages/sf-game-data/data/*/Docs.json

# Satisfactory save files (player data — never commit; used locally for inspect)
*.sav

# Dependencies
node_modules/

# Build output
dist/
build/

# Local databases (Prisma SQLite dev/test)
*.db
*.db-journal
*.sqlite

# Environment
.env
.env.local

# Logs
*.log
npm-debug.log*

# OS / editor
.DS_Store
.idea/
.vscode/

# Auto-generated Better Auth signing secret (persisted next to the DB)
.better-auth-secret

# Host-local extractor scratch (CUE4Parse clone lives under
# packages/sf-game-data/extract/; this is for throwaway probes/experiments)
/tools/
