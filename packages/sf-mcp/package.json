{
  "name": "@foreman/sf-mcp",
  "version": "0.1.0",
  "description": "FICSIT Foreman unified MCP server: serves the Satisfactory game-data graph tools and live save-game tools from one endpoint.",
  "license": "Apache-2.0",
  "type": "module",
  "bin": {
    "foreman-sf-mcp": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "inspect:game-data": "tsx src/scripts/inspectGameData.ts",
    "inspect:save": "tsx src/scripts/inspectSave.ts",
    "lint": "eslint . --max-warnings 0 && prettier --check \"src/**/*.ts\"",
    "format": "prettier --write \"src/**/*.ts\""
  },
  "dependencies": {
    "@foreman/sf-flow": "0.1.0",
    "@foreman/sf-game-data": "0.1.0",
    "@foreman/sf-game-data-graph": "0.1.0",
    "@foreman/sf-present": "0.1.0",
    "@foreman/sf-save-data": "0.1.0",
    "@foreman/sf-save-data-graph": "0.1.0",
    "@modelcontextprotocol/sdk": "^1.12.0",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/express": "^5.0.6",
    "@types/node": "^26.0.0",
    "@typescript-eslint/eslint-plugin": "^8.62.0",
    "@typescript-eslint/parser": "^8.62.0",
    "eslint": "^10.5.0",
    "prettier": "^3.3.0",
    "tsx": "^4.16.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
