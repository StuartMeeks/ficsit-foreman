{
  "name": "@foreman/sf-game-data",
  "version": "0.1.0",
  "description": "FICSIT Foreman shared game-data core: the hand-written Satisfactory en-US.json parser, shared types, docs-path resolution, and bundled game data. Consumed by both MCP servers.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js"
  },
  "files": [
    "dist",
    "data"
  ],
  "dependencies": {
    "@foreman/sf-core": "0.1.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint . --max-warnings 0 && prettier --check \"src/**/*.ts\"",
    "format": "prettier --write \"src/**/*.ts\""
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^26.1.1",
    "@typescript-eslint/eslint-plugin": "^8.64.0",
    "@typescript-eslint/parser": "^8.62.0",
    "eslint": "^10.7.0",
    "prettier": "^3.9.5",
    "tsx": "^4.23.1",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  }
}
