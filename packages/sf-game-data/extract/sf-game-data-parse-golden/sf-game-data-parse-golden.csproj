<Project Sdk="Microsoft.NET.Sdk">

  <!--
    Dev harness for the golden-diff gate (#159): parses an en-US.json with the C#
    parser and writes the ParseResult as JSON, to be compared against the
    TypeScript parser's output (scripts/parse-golden-dump.mjs + parse-golden-compare.mjs).
    CUE4Parse-free, so it builds and runs on the dev VM.
  -->
  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\sf-game-data-parse\sf-game-data-parse.csproj" />
  </ItemGroup>

</Project>
