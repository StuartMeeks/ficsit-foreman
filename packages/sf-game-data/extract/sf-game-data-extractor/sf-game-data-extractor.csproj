<Project Sdk="Microsoft.NET.Sdk">

  <!--
    The single offline game-data producer (see docs/sf-game-data-extractor.md).
    A thin console front end over `sf-game-data-extraction`; building this project
    builds the library too. CUE4Parse arrives transitively via the library.
  -->
  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\sf-game-data-extraction\sf-game-data-extraction.csproj" />
    <ProjectReference Include="..\sf-game-data-parse\sf-game-data-parse.csproj" />
  </ItemGroup>

</Project>
