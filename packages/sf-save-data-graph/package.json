{
  "name": "@foreman/sf-save-data-graph",
  "version": "0.1.0",
  "description": "Save-game connection graph for Satisfactory: reconstructs the factory's conveyor/pipe/power connectivity from a parsed .sav (@foreman/sf-save-data) as an in-memory, game-data-agnostic graph. The substrate every relational save question (power, production feed-tracing, logistics, map adjacency) queries.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "dependencies": {
    "@foreman/sf-save-data": "0.1.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "inspect": "tsx src/scripts/inspect.ts",
    "lint": "eslint . --max-warnings 0 && prettier --check \"src/**/*.ts\"",
    "format": "prettier --write \"src/**/*.ts\""
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^26.0.0",
    "@typescript-eslint/eslint-plugin": "^8.62.0",
    "@typescript-eslint/parser": "^8.62.0",
    "eslint": "^10.5.0",
    "prettier": "^3.3.0",
    "tsx": "^4.16.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
