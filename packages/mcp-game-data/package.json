{
  "name": "@foreman/mcp-game-data",
  "version": "0.1.0",
  "description": "FICSIT Foreman game-data MCP server: parses Satisfactory game data into an embedded Kùzu graph and exposes it as computed MCP tools.",
  "license": "Apache-2.0",
  "type": "module",
  "bin": {
    "foreman-mcp-game-data": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint . && prettier --check \"src/**/*.ts\"",
    "format": "prettier --write \"src/**/*.ts\"",
    "inspect": "tsx src/scripts/inspect.ts"
  },
  "dependencies": {
    "@foreman/game-data-core": "0.1.0",
    "@modelcontextprotocol/sdk": "^1.12.0",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "kuzu": "^0.11.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/express": "^5.0.6",
    "@types/node": "^26.0.0",
    "@typescript-eslint/eslint-plugin": "^8.62.0",
    "@typescript-eslint/parser": "^8.62.0",
    "eslint": "^10.5.0",
    "prettier": "^3.3.0",
    "tsx": "^4.16.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
