// FICSIT Foreman backend database schema.
//
// SQLite for local dev (DATABASE_URL=file:./dev.db); the same schema migrates
// to Postgres for hosted deployment. Complex work-order fields (arrays, nested
// objects) are stored as JSON-encoded TEXT rather than native arrays/JSON so the
// schema is portable across both providers without change. The service layer
// owns serialisation; the WorkOrder shape that crosses the API matches SPEC.md.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

// A reusable foreman persona, owned by a user and attachable to many
// playthroughs (#86). `personality` is the opaque freeform string injected into
// the system prompt as {{PERSONALITY}}. `userId` is nullable to mirror
// Playthrough: a pre-accounts anonymous playthrough carries an anonymous
// foreman until both are claimed on first login.
model Foreman {
  id          String   @id @default(uuid())
  userId      String?
  name        String
  personality String   @default("")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user         User?         @relation(fields: [userId], references: [id], onDelete: Cascade)
  playthroughs Playthrough[]

  @@index([userId])
}

// A playthrough: one save's journey — a chosen foreman + the pioneer's play
// style + the conversation and its work. This is the former `Session` (#86).
// Owned by a User (accounts, #63); `userId` is nullable so a pre-accounts
// anonymous playthrough can be re-homed to a user on first login. `name` is
// freely editable (defaulted from the attached save once #76 lands).
// `pioneerProfile` lives here, not on the user, because play style varies per
// run; it is injected into the system prompt as {{PIONEER_PROFILE}}.
model Playthrough {
  id             String   @id
  userId         String?
  foremanId      String
  name           String?
  pioneerProfile String   @default("")
  // Running condensed record of the playthrough, regenerated in the background
  // once the conversation has rolled past the history window. Null until first
  // summarised; injected into the system prompt as {{SESSION_SUMMARY}}.
  summary        String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user       User?       @relation(fields: [userId], references: [id], onDelete: Cascade)
  foreman    Foreman     @relation(fields: [foremanId], references: [id], onDelete: Restrict)
  save       Save?
  messages   Message[]
  workOrders WorkOrder[]

  @@index([userId])
  @@index([foremanId])
}

// The current uploaded `.sav` for a playthrough (#61, minimal slice of #76).
// One current save per playthrough (latest-only for v1: re-uploading replaces
// it; a version history is deferred to #76). The bytes live on a data volume at
// `${SAVE_DATA_DIR}/<playthroughId>.sav`; this row carries the metadata parsed
// from the save (its in-game name + game/build version) which seeds the
// playthrough's default name and is surfaced in the UI.
model Save {
  id                  String   @id @default(uuid())
  playthroughId       String   @unique
  fileName            String // the original uploaded filename
  saveName            String? // in-game session/save name parsed from the header
  version             String? // humanised game build + save format parsed from the header
  // Discrete header identity (parsed via describe_save) — powers the
  // build-version warning now and same-game recognition later (#76).
  sessionName         String? // raw in-game session name
  mapName             String? // e.g. Persistent_Level
  buildVersion        Int? // Satisfactory changelist/build number (comparable to game data's build)
  saveVersion         Int? // save-format version
  playDurationSeconds Int? // total in-game play time
  sizeBytes           Int
  uploadedAt          DateTime @default(now())

  playthrough Playthrough @relation(fields: [playthroughId], references: [id], onDelete: Cascade)
}

// A single persisted conversational turn. Only user input and the foreman's
// final assistant text are stored — the intermediate tool-use round-trips happen
// within a single chat request and are not persisted, keeping history valid and
// trivially windowable.
model Message {
  id            String      @id @default(uuid())
  playthroughId String
  playthrough   Playthrough @relation(fields: [playthroughId], references: [id], onDelete: Cascade)
  role          String // 'user' | 'assistant'
  content       String // plain text of the turn
  createdAt     DateTime    @default(now())

  @@index([playthroughId, createdAt])
}

// A work order. Mirrors the WorkOrder interface in WORK_ORDER_SPEC.md (Work
// Orders v2). Sequence numbers are per-playthrough and monotonic (rendered
// WO-001, WO-002, …). At most one order per playthrough may be `active` at a
// time, but multiple non-terminal orders may coexist (e.g. a blocked parent +
// an active child) — enforced in the service layer.
//
// Plan vs execution are separated: plan fields (Foreman-owned) are snapshotted
// into WorkOrderRevision on every plan change; execution fields (Pioneer-owned —
// checked flags inside the checklists, machine built counts, hoursLogged) live
// only here and their history is the WorkOrderAuditEvent trail, never snapshots.
model WorkOrder {
  id             String      @id @default(uuid())
  playthroughId  String
  playthrough    Playthrough @relation(fields: [playthroughId], references: [id], onDelete: Cascade)
  sequenceNumber Int
  state          String // WorkOrderState: new|active|paused|blocked|completed|cancelled|superseded
  version        String // game data version this order was built for

  // Plan — Foreman-owned. Complex fields are JSON-encoded TEXT (portable
  // SQLite→Postgres). Checklist JSON carries stable ids + execution state.
  title                  String
  goal                   String
  objective              String?
  strategicSignificance  String?
  successCondition       String?
  tier                   Int?
  notes                  String? // JSON string[] of foreman build notes
  locationRecommendation String? // JSON LocationRecommendation
  resourceNodes          String? // JSON ResourceNodeReference[]
  machines               String  @default("[]") // JSON MachineRequirement[]
  buildMaterials         String  @default("[]") // JSON MaterialRequirement[]
  recipes                String  @default("[]") // JSON RecipeAssignment[]
  expectedOutputs        String  @default("[]") // JSON ExpectedOutput[]
  buildSteps             String  @default("[]") // JSON WorkOrderStep[]
  opportunities          String? // JSON WorkOrderOpportunities
  blockedReason          String?
  blockedResolutionHint  String?

  // Execution — Pioneer-owned.
  startedAt         DateTime?
  pausedAt          DateTime?
  blockedAt         DateTime?
  completedAt       DateTime?
  hoursLogged       Float?
  completionSummary String?
  pioneerFeedback   String? // JSON PioneerFeedback

  // Revision / acknowledgement (plan revisions only).
  currentRevision          Int  @default(1)
  lastAcknowledgedRevision Int?

  // Relationships. Children are derived by querying parentWorkOrderId.
  parentWorkOrderId    String?
  relationshipToParent String? // WorkOrderRelationshipType

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  revisions   WorkOrderRevision[]
  auditEvents WorkOrderAuditEvent[]

  @@unique([playthroughId, sequenceNumber])
  @@index([playthroughId, state])
  @@index([parentWorkOrderId])
}

// A full plan snapshot, written on every plan change (and on revert). Stores
// plan fields ONLY — never execution state. Append-only; revert copies a prior
// snapshot into a new revision rather than mutating history.
model WorkOrderRevision {
  id             String    @id @default(uuid())
  workOrderId    String
  workOrder      WorkOrder @relation(fields: [workOrderId], references: [id], onDelete: Cascade)
  revisionNumber Int
  createdAt      DateTime  @default(now())
  createdBy      String // WorkOrderActor
  reason         String?
  changeSummary  String?
  planSnapshot   String // JSON WorkOrderPlanSnapshot

  @@unique([workOrderId, revisionNumber])
  @@index([workOrderId])
}

// Append-only audit trail. Every mutating operation appends one of these;
// execution mutations append here WITHOUT writing a revision snapshot.
model WorkOrderAuditEvent {
  id                     String    @id @default(uuid())
  workOrderId            String
  workOrder              WorkOrder @relation(fields: [workOrderId], references: [id], onDelete: Cascade)
  timestamp              DateTime  @default(now())
  actor                  String // WorkOrderActor
  eventType              String // WorkOrderAuditEventType
  revisionNumber         Int?
  previousRevisionNumber Int?
  note                   String?
  details                String? // JSON

  @@index([workOrderId, timestamp])
}

// ── Better Auth (#63) ───────────────────────────────────────────────────────
// Tables owned by Better Auth (https://better-auth.com). Field names match its
// core schema; our config maps Better Auth's `session` model to `AuthSession`
// here to avoid colliding with the play `Session` above. Email+password is the
// first factor; passkey/two-factor tables are added in the MFA slice.

model User {
  id               String   @id
  name             String
  email            String   @unique
  emailVerified    Boolean  @default(false)
  image            String?
  twoFactorEnabled Boolean? @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  authSessions AuthSession[]
  accounts     Account[]
  twoFactors   TwoFactor[]
  foremen      Foreman[] // the user's reusable foreman personas
  playthroughs Playthrough[] // the user's playthroughs

  @@map("user")
}

model AuthSession {
  id        String   @id
  token     String   @unique
  userId    String
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("authSession")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

// Two-factor (MFA) secret + backup codes for a user. Written by the twoFactor
// plugin when the pioneer enrols TOTP; one row per user.
model TwoFactor {
  id          String  @id
  secret      String
  backupCodes String
  verified    Boolean @default(true)
  userId      String
  user        User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([secret])
  @@index([userId])
  @@map("twoFactor")
}
