// FICSIT Foreman backend database schema.
//
// SQLite for local dev (DATABASE_URL=file:./dev.db); the same schema migrates
// to Postgres for hosted deployment. Complex work-order fields (arrays, nested
// objects) are stored as JSON-encoded TEXT rather than native arrays/JSON so the
// schema is portable across both providers without change. The service layer
// owns serialisation; the WorkOrder shape that crosses the API matches SPEC.md.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

// A play session. Owned by a User (accounts, #63). `userId` is nullable so a
// pre-accounts anonymous session can be re-homed to a user on first login;
// authed creates always set it. Personality and pioneer profile are opaque
// freeform strings injected into the foreman system prompt at request time.
model Session {
  id             String   @id
  userId         String?
  personality    String   @default("")
  pioneerProfile String   @default("")
  // Running condensed record of the session, regenerated in the background once
  // the conversation has rolled past the history window. Null until first
  // summarised; injected into the system prompt as {{SESSION_SUMMARY}}.
  summary        String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user       User?       @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages   Message[]
  workOrders WorkOrder[]

  @@index([userId])
}

// A single persisted conversational turn. Only user input and the foreman's
// final assistant text are stored — the intermediate tool-use round-trips happen
// within a single chat request and are not persisted, keeping history valid and
// trivially windowable.
model Message {
  id        String   @id @default(uuid())
  sessionId String
  session   Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  role      String // 'user' | 'assistant'
  content   String // plain text of the turn
  createdAt DateTime @default(now())

  @@index([sessionId, createdAt])
}

// A work order. Mirrors the WorkOrder interface in WORK_ORDER_SPEC.md (Work
// Orders v2). Sequence numbers are per-session and monotonic (rendered WO-001,
// WO-002, …). At most one order per session may be `active` at a time, but
// multiple non-terminal orders may coexist (e.g. a blocked parent + an active
// child) — enforced in the service layer.
//
// Plan vs execution are separated: plan fields (Foreman-owned) are snapshotted
// into WorkOrderRevision on every plan change; execution fields (Pioneer-owned —
// checked flags inside the checklists, machine built counts, hoursLogged) live
// only here and their history is the WorkOrderAuditEvent trail, never snapshots.
model WorkOrder {
  id             String  @id @default(uuid())
  sessionId      String
  session        Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  sequenceNumber Int
  state          String // WorkOrderState: new|active|paused|blocked|completed|cancelled|superseded
  version        String // game data version this order was built for

  // Plan — Foreman-owned. Complex fields are JSON-encoded TEXT (portable
  // SQLite→Postgres). Checklist JSON carries stable ids + execution state.
  title                 String
  goal                  String
  objective             String?
  strategicSignificance String?
  successCondition      String?
  tier                  Int?
  notes                 String? // JSON string[] of foreman build notes
  locationRecommendation String? // JSON LocationRecommendation
  resourceNodes          String? // JSON ResourceNodeReference[]
  machines               String  @default("[]") // JSON MachineRequirement[]
  buildMaterials         String  @default("[]") // JSON MaterialRequirement[]
  recipes                String  @default("[]") // JSON RecipeAssignment[]
  expectedOutputs        String  @default("[]") // JSON ExpectedOutput[]
  buildSteps             String  @default("[]") // JSON WorkOrderStep[]
  opportunities          String? // JSON WorkOrderOpportunities
  blockedReason          String?
  blockedResolutionHint  String?

  // Execution — Pioneer-owned.
  startedAt         DateTime?
  pausedAt          DateTime?
  blockedAt         DateTime?
  completedAt       DateTime?
  hoursLogged       Float?
  completionSummary String?
  pioneerFeedback   String? // JSON PioneerFeedback

  // Revision / acknowledgement (plan revisions only).
  currentRevision         Int  @default(1)
  lastAcknowledgedRevision Int?

  // Relationships. Children are derived by querying parentWorkOrderId.
  parentWorkOrderId    String?
  relationshipToParent String? // WorkOrderRelationshipType

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  revisions   WorkOrderRevision[]
  auditEvents WorkOrderAuditEvent[]

  @@unique([sessionId, sequenceNumber])
  @@index([sessionId, state])
  @@index([parentWorkOrderId])
}

// A full plan snapshot, written on every plan change (and on revert). Stores
// plan fields ONLY — never execution state. Append-only; revert copies a prior
// snapshot into a new revision rather than mutating history.
model WorkOrderRevision {
  id             String    @id @default(uuid())
  workOrderId    String
  workOrder      WorkOrder @relation(fields: [workOrderId], references: [id], onDelete: Cascade)
  revisionNumber Int
  createdAt      DateTime  @default(now())
  createdBy      String // WorkOrderActor
  reason         String?
  changeSummary  String?
  planSnapshot   String // JSON WorkOrderPlanSnapshot

  @@unique([workOrderId, revisionNumber])
  @@index([workOrderId])
}

// Append-only audit trail. Every mutating operation appends one of these;
// execution mutations append here WITHOUT writing a revision snapshot.
model WorkOrderAuditEvent {
  id                     String    @id @default(uuid())
  workOrderId            String
  workOrder              WorkOrder @relation(fields: [workOrderId], references: [id], onDelete: Cascade)
  timestamp              DateTime  @default(now())
  actor                  String // WorkOrderActor
  eventType              String // WorkOrderAuditEventType
  revisionNumber         Int?
  previousRevisionNumber Int?
  note                   String?
  details                String? // JSON

  @@index([workOrderId, timestamp])
}

// ── Better Auth (#63) ───────────────────────────────────────────────────────
// Tables owned by Better Auth (https://better-auth.com). Field names match its
// core schema; our config maps Better Auth's `session` model to `AuthSession`
// here to avoid colliding with the play `Session` above. Email+password is the
// first factor; passkey/two-factor tables are added in the MFA slice.

model User {
  id               String   @id
  name             String
  email            String   @unique
  emailVerified    Boolean  @default(false)
  image            String?
  twoFactorEnabled Boolean? @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  authSessions AuthSession[]
  accounts     Account[]
  twoFactors   TwoFactor[]
  sessions     Session[] // the user's play sessions

  @@map("user")
}

model AuthSession {
  id        String   @id
  token     String   @unique
  userId    String
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("authSession")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

// Two-factor (MFA) secret + backup codes for a user. Written by the twoFactor
// plugin when the pioneer enrols TOTP; one row per user.
model TwoFactor {
  id          String  @id
  secret      String
  backupCodes String
  verified    Boolean @default(true)
  userId      String
  user        User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([secret])
  @@index([userId])
  @@map("twoFactor")
}
