{
  "name": "foreman",
  "version": "0.1.0",
  "private": true,
  "description": "FICSIT Foreman — AI companion for Satisfactory. MCP game-data server + foreman chat backend.",
  "license": "Apache-2.0",
  "author": "Stu",
  "workspaces": [
    "packages/*"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "dev": "npm run dev -w @foreman/mcp-game-data",
    "dev:mcp": "npm run dev -w @foreman/mcp-game-data",
    "dev:server": "npm run dev -w @foreman/server",
    "dev:web": "npm run dev -w @foreman/client",
    "start:mcp": "npm run start -w @foreman/mcp-game-data",
    "start:server": "npm run start -w @foreman/server",
    "inspect": "npm run inspect -w @foreman/mcp-game-data --"
  }
}
